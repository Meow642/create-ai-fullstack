{
  "name": "create-ai-fullstack",
  "version": "0.3.0-alpha.3",
  "description": "Create an AI-friendly fullstack pnpm monorepo template.",
  "type": "module",
  "bin": {
    "create-ai-fullstack": "dist/index.mjs"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "dev:template": "bash scripts/dev-template.sh",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "node --test \"test/**/*.test.mjs\"",
    "verify": "pnpm build && bash scripts/verify-template.sh",
    "release": "node scripts/publish.mjs",
    "release:dry-run": "node scripts/publish.mjs --dry-run"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "cac": "^7.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "license": "MIT"
}
