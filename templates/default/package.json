{
  "name": "{{PROJECT_NAME}}",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r --if-present run test:coverage",
    "gen:openapi": "pnpm -F api gen:openapi",
    "validate:openapi": "redocly lint api-contracts/api/openapi.yaml --extends=minimal --skip-rule=no-empty-servers --skip-rule=operation-operationId --skip-rule=no-unused-components --skip-rule=security-defined",
    "verify:contracts": "pnpm gen:openapi && node scripts/check-contract-drift.mjs",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@redocly/cli": "^2.30.3",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "core-js",
      "msw",
      "protobufjs"
    ],
    "allowedDeprecatedVersions": {
      "node-domexception": "1.0.0",
      "prebuild-install": "7.1.3"
    }
  }
}
